APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./crowd_tracking.db

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# AI Engine: "mock" hoặc "crowd_tracking"
AI_ENGINE=crowd_tracking
# AI_ENGINE=mock

DEFAULT_CAMERA_SOURCE_TYPE=mock
DEFAULT_CAMERA_SOURCE_URL=

HARDWARE_PROVIDER=mock_public_api
MOCK_HARDWARE_URL=https://httpbin.org/post
REAL_HARDWARE_BASE_URL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

ALERT_COOLDOWN_SECONDS=30
SNAPSHOT_DIR=web/app/static/snapshots
